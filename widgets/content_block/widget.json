{
  "version": "1.0.0",
  "title": "Content Block",
  "description": "Configurable text and HTML content block for 2:1 containers",
  "category": "Content",
  "imageName": "content_block",
  "containers": ["Full width", "Left container"],
  "source": {
    "path": "dist",
    "entry": "content.html"
  },
  "configuration": {
    "properties": [
      {
        "name": "title",
        "type": "text",
        "label": "Title",
        "defaultValue": ""
      },
      {
        "name": "content",
        "type": "text",
        "label": "Content (plain text or HTML)",
        "defaultValue": ""
      },
      {
        "name": "alignment",
        "type": "select",
        "label": "Text Alignment",
        "options": [
          { "label": "Left", "value": "left" },
          { "label": "Center", "value": "center" },
          { "label": "Right", "value": "right" }
        ],
        "defaultValue": "left"
      },
      {
        "name": "backgroundColor",
        "type": "color",
        "label": "Background Color",
        "defaultValue": "#ffffff"
      },
      {
        "name": "textColor",
        "type": "color",
        "label": "Text Color",
        "defaultValue": "#000000"
      },
      {
        "name": "padding",
        "type": "select",
        "label": "Padding",
        "options": [
          { "label": "None", "value": "none" },
          { "label": "Small", "value": "small" },
          { "label": "Medium", "value": "medium" },
          { "label": "Large", "value": "large" }
        ],
        "defaultValue": "medium"
      }
    ]
  }
}
