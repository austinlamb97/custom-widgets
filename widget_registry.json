{
  "widgets": [
    {
      "category": "Content",
      "configuration": {
        "properties": [
          {
            "name": "title",
            "type": "text",
            "label": "Title",
            "defaultValue": ""
          },
          {
            "name": "content",
            "type": "text",
            "label": "Content (plain text or HTML)",
            "defaultValue": ""
          },
          {
            "name": "alignment",
            "type": "select",
            "label": "Text Alignment",
            "options": [
              { "label": "Left", "value": "left" },
              { "label": "Center", "value": "center" },
              { "label": "Right", "value": "right" }
            ],
            "defaultValue": "left"
          },
          {
            "name": "backgroundColor",
            "type": "color",
            "label": "Background Color",
            "defaultValue": "#ffffff"
          },
          {
            "name": "textColor",
            "type": "color",
            "label": "Text Color",
            "defaultValue": "#000000"
          },
          {
            "name": "padding",
            "type": "select",
            "label": "Padding",
            "options": [
              { "label": "None", "value": "none" },
              { "label": "Small", "value": "small" },
              { "label": "Medium", "value": "medium" },
              { "label": "Large", "value": "large" }
            ],
            "defaultValue": "medium"
          }
        ]
      },
      "containers": ["Full width", "Left container"],
      "description": "Configurable text and HTML content block for 2:1 containers",
      "imageName": "content_block",
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "title": "Content Block",
      "version": "1.0.0",
      "widgetsLibrary": true,
      "type": "content_block",
      "source": {
        "path": "widgets/content_block/dist",
        "entry": "content.html"
      }
    },
    {
      "type": "weather_widget",
      "title": "Weather Widget",
      "version": "1.0.0",
      "description": "Displays current weather conditions for a configured city using Open-Meteo.",
      "category": "General",
      "imageName": "weather_widget",
      "containers": ["Full width"],
      "widgetsLibrary": true,
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "source": {
        "path": "widgets/weather_widget/dist",
        "entry": "content.html"
      },
      "configuration": {
        "properties": [
          { "name": "city", "type": "text", "label": "City Name", "defaultValue": "St. Louis" },
          { "name": "latitude", "type": "text", "label": "Latitude", "defaultValue": "38.6270" },
          { "name": "longitude", "type": "text", "label": "Longitude", "defaultValue": "-90.1994" },
          {
            "name": "units",
            "type": "select",
            "label": "Temperature Units",
            "defaultValue": "fahrenheit",
            "options": [
              { "label": "Fahrenheit", "value": "fahrenheit" },
              { "label": "Celsius", "value": "celsius" }
            ]
          }
        ]
      }
    },
    {
      "category": "Salesforce",
      "containers": ["Full width"],
      "description": "Submit a Salesforce lead referral from the community",
      "imageName": "salesforce_widget",
      "settings": {
        "configurable": true,
        "editable": true,
        "removable": true,
        "shared": false,
        "movable": false
      },
      "title": "Salesforce lead form",
      "version": "1.0.0",
      "widgetsLibrary": true,
      "type": "salesforce_lead_form",
      "source": {
        "path": "widgets/salesforce_lead_form/dist",
        "entry": "content.html"
      }
    }
  ]
}
